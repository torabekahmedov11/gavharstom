// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String        @id @default(uuid())
  telegramId    String?       @unique
  phoneNumber   String?
  firstName     String
  lastName      String?
  birthDate     DateTime?
  registeredAt  DateTime      @default(now())
  
  appointments  Appointment[]
  medicalRecords MedicalRecord[]
}

model Doctor {
  id             String        @id @default(uuid())
  firstName      String
  lastName       String
  specialization String
  isActive       Boolean       @default(true)
  
  appointments   Appointment[]
}

model Service {
  id              String        @id @default(uuid())
  name            String
  price           Float
  durationMinutes Int           // O'rtacha davomiylik (masalan 30 min)
  
  appointments    Appointment[]
}

model Appointment {
  id          String   @id @default(uuid())
  
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  
  date        DateTime // Qabul qilinadigan kun
  startTime   DateTime // Boshlanish vaqti
  endTime     DateTime // Tugash vaqti (startTime + xizmat duration)
  
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, DELAYED
  isLiveQueue Boolean  @default(false)     // Jonli navbatmi yoki onlaynmi?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  medicalRecord MedicalRecord?
}

model MedicalRecord {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  
  description   String       // Nima ish qilingani (masalan: 46-tish yulindi)
  totalPrice    Float        // Umumiy summa
  
  createdAt     DateTime     @default(now())
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Haqiqiy loyihada hash qilinishi kerak
  role      String   @default("ADMIN") // ADMIN, DIRECTOR
  createdAt DateTime @default(now())
}
